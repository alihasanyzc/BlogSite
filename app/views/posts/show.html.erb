<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-body">
        <h1><%= @post.title %></h1>
        <div class="mb-3">
          <small class="text-muted">
            By <%= link_to @post.user.username, user_path(@post.user.username), class: "text-decoration-none" %>
            in <%= link_to @post.category.name, category_path(@post.category), class: "text-decoration-none" %>
            • <%= time_ago_in_words(@post.created_at) %> ago
          </small>
        </div>
        <div class="mb-4">
          <%= simple_format(@post.body) %>
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <% if logged_in? %>
              <% if @post.liked_by?(current_user) %>
                <%= button_to unlike_post_path(@post), method: :delete, class: "btn btn-outline-danger btn-sm", form_class: "d-inline" do %>
                  ♥ <%= @post.likes_count %>
                <% end %>
              <% else %>
                <%= button_to like_post_path(@post), method: :post, class: "btn btn-outline-primary btn-sm", form_class: "d-inline" do %>
                  ♡ <%= @post.likes_count %>
                <% end %>
              <% end %>
            <% else %>
              <span class="text-muted">♡ <%= @post.likes_count %></span>
            <% end %>
          </div>
          
          <% if logged_in? && @post.user == current_user %>
            <div>
              <%= link_to "Edit", edit_post_path(@post), class: "btn btn-outline-secondary btn-sm" %>
              <%= button_to "Delete", @post, method: :delete, 
                          data: { turbo_confirm: "Bu gönderiyi silmek istediğinize emin misiniz?" }, class: "btn btn-outline-danger btn-sm", form_class: "d-inline" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Comments Section -->
    <div class="mt-4">
      <h4>Comments (<%= @comments.count %>)</h4>
      
      <% if logged_in? %>
        <div class="card mb-4">
          <div class="card-body">
            <%= form_with model: [@post, @comment], local: true do |form| %>
              <div class="mb-3">
                <%= form.text_area :body, class: "form-control", rows: 3, placeholder: "Add a comment..." %>
              </div>
              <%= form.submit "Post Comment", class: "btn btn-primary" %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="alert alert-info">
          <%= link_to "Login", login_path %> to post a comment.
        </div>
      <% end %>

      <% @comments.each do |comment| %>
        <div class="card mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <strong><%= comment.user.username %></strong>
              <div>
                <small class="text-muted"><%= time_ago_in_words(comment.created_at) %> ago</small>
                <% if logged_in? && comment.user == current_user %>
                  <%= button_to "Delete", [@post, comment], method: :delete, 
                              data: { turbo_confirm: "Bu yorumu silmek istediğinize emin misiniz?" }, class: "btn btn-outline-danger btn-sm ms-2", form_class: "d-inline" %>
                <% end %>
              </div>
            </div>
            <p class="mt-2 mb-0"><%= simple_format(comment.body) %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5>About Author</h5>
      </div>
      <div class="card-body">
        <h6><%= @post.user.username %></h6>
        <% if @post.user.profile&.bio.present? %>
          <p><%= @post.user.profile.bio %></p>
        <% end %>
        <p class="text-muted">
          <%= pluralize(@post.user.posts.count, 'post') %> written
        </p>
        <%= link_to "View Profile", user_path(@post.user.username), class: "btn btn-outline-primary btn-sm" %>
      </div>
    </div>
  </div>
</div>

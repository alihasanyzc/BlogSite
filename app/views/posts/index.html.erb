<div class="row">
  <div class="col-md-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Latest Posts</h1>
      <% if logged_in? %>
        <%= link_to "New Post", new_post_path, class: "btn btn-primary" %>
      <% end %>
    </div>

    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="card mb-4">
          <div class="card-body">
            <h5 class="card-title">
              <%= link_to post.title, post, class: "text-decoration-none" %>
            </h5>
            <p class="card-text"><%= truncate(post.body, length: 200) %></p>
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-muted">
                  By <%= link_to post.user.username, user_path(post.user.username), class: "text-decoration-none" %>
                  in <%= link_to post.category.name, category_path(post.category), class: "text-decoration-none" %>
                </small>
              </div>
              <div>
                <small class="text-muted">
                  <%= pluralize(post.likes_count, 'like') %> • 
                  <%= pluralize(post.comments.count, 'comment') %> • 
                  <%= time_ago_in_words(post.created_at) %> ago
                </small>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <h4>No posts yet!</h4>
        <p class="text-muted">Be the first to share your thoughts.</p>
        <% if logged_in? %>
          <%= link_to "Create First Post", new_post_path, class: "btn btn-primary" %>
        <% else %>
          <%= link_to "Sign Up", signup_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5>Categories</h5>
      </div>
      <div class="card-body">
        <%= link_to "All Posts", root_path, class: "btn btn-outline-primary btn-sm mb-2 #{'active' unless params[:category_id]}" %>
        <% @categories.each do |category| %>
          <%= link_to category.name, root_path(category_id: category.id), 
                      class: "btn btn-outline-secondary btn-sm mb-2 #{'active' if params[:category_id] == category.id.to_s}" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
